    <title>chxry</title>
    <link rel="icon" href="/icon.png" type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;800&display=swap" />
  </head>
  <body class="mocha bg-dots text-text font-mono text-sm md:text-[1rem] md:leading-6">
    <div class="max-w-[50rem] mx-auto p-2 md:p-6">
      <h1 class="font-extrabold text-5xl md:text-7xl mb-2">
        <img class="inline h-[1em] mr-2 rounded-sm" src="/icon.png" />chxry
      </h1>
      <slot />
      {!Astro.props.home && <a href="/" class="underline text-blue">← back</a>}
      <p class="fixed bottom-2 text-sm text-subtext0">
